#!/usr/bin/env bash
set -euo pipefail

if [[ "${BLOG_SKIP_PRECOMMIT_BUILD:-0}" == "1" ]]; then
  exit 0
fi

ROOT_DIR="$(git rev-parse --show-toplevel)"
cd "$ROOT_DIR"

if ! git diff --cached --name-only | grep -Eq '^(blog-source/|scripts/|docs/)'; then
  exit 0
fi

echo "pre-commit: building and syncing Hexo site..."
"$ROOT_DIR/scripts/post.sh" build
cp -a "$ROOT_DIR/blog-source/public/." "$ROOT_DIR/"

paths=(
  404.html
  about
  archives
  atom.xml
  blog-source/_config.yml
  blog-source/_config.stellar.yml
  blog-source/package.json
  blog-source/package-lock.json
  blog-source/source
  categories
  css/main.css
  css/stellar-custom.css
  img
  index.html
  js
  page
  scripts
  search.json
  tags
)

while IFS= read -r -d '' year_dir; do
  paths+=("$year_dir")
done < <(find . -maxdepth 1 -type d -regextype posix-extended -regex './[0-9]{4}' -printf '%P\0')

for path in "${paths[@]}"; do
  if [[ -e "$path" ]]; then
    git add -A -- "$path"
  fi
done
